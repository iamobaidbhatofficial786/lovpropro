# =========================================================================
# CHROME EXTENSION LICENSING & PROTECTION SYSTEM - ENVIRONMENT VARIABLES
# Copy this file to .env in your vercel-api and admin-dashboard directories
# =========================================================================

# --- Supabase Database Configuration ---
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key-bypass-rls"

# --- Admin Panel Authentication ---
# Secret used to sign admin session tokens and protect admin endpoints
ADMIN_SECRET="some-long-cryptographically-secure-random-string"

# --- JWT Cryptographic Security (RS256) ---
# Vercel API signs tokens using the Private Key.
# Chrome Extension checks token signatures using the Public Key.
#
# HOW TO GENERATE A COMPATIBLE RS256 KEY PAIR:
# Open terminal and run:
#   1. Generate private key:
#      openssl genrsa -out private.pem 2048
#   2. Convert private key to PKCS8 format:
#      openssl pkcs8 -topk8 -inform PEM -outform PEM -nocrypt -in private.pem -out pkcs8_private.pem
#   3. Extract public key:
#      openssl rsa -in private.pem -pubout -out public.pem
#
# Paste contents below. Escaped newlines (\n) are handled automatically by the API.

JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIICdgIBADANBgkqhkiG9w0BAQEFAASCAmAwggJcAgEAAoGBAM6l96uHCsSY/5/N...\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA4vR47gex2W5eZl+qj136...\n-----END PUBLIC KEY-----"

# --- Upstream Proxy Routing ---
# Original base url of the extension features backend (defaults to https://lov.powerkits.net)
UPSTREAM_API_BASE="https://lov.powerkits.net"

# Original master extension api key (used to forward validated calls upstream)
POWERKITS_API_KEY="pk_lov_ext_a8f3c21e9d4b7f0e6a2c5d8b1e4f7a0c"

# --- Deployment Configuration ---
# Vercel base endpoint url (e.g. https://your-app.vercel.app)
VERCEL_URL="https://your-vercel-deployment.vercel.app"
# Next.js Public keys (required for client-side Supabase client initialization in Dashboard)
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
